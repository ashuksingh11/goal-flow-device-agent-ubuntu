# GoalFlow device agent v2 — LLM configuration (OpenRouter, OpenAI-compatible).
# v2 is LLM-ONLY: planning always goes through the SK kernel, so these are
# required. Copy to .env and fill in.

OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b

# Per-call LLM deadlines (seconds). Raise these if a large/slow model or provider load
# cancels planning mid-compose ("transient provider error (TaskCanceledException)"); a
# healthy compose finishes well under the default. Optional — defaults apply if unset.
# LLM_CALL_TIMEOUT_SECONDS=180     # non-streaming compose / adaptation
# LLM_STREAM_TIMEOUT_SECONDS=210   # streaming grounding pass
