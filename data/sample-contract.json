{
  "type": "dispatch",
  "goal_id": "meal-week-demo",
  "correlation_id": "disp-001",
  "domain": "meal_plan",
  "objective": "healthier family dinners, less food waste",
  "success_criteria": [
    "a dinner planned for each weekday in the window",
    "expiring inventory used before it spoils",
    "grocery spend within the budget cap"
  ],
  "constraints": {
    "hard": {
      "allergens": [],
      "dietary": ["no_pork"],
      "medical": [],
      "budget_cap": 60.0
    },
    "soft": {
      "dislikes": ["mushrooms"],
      "prefer": ["more_vegetables", "more_protein"]
    }
  },
  "scope": {
    "meal": "dinner",
    "days": ["Mon", "Tue", "Wed", "Thu", "Fri"]
  },
  "time_window": {
    "start": "${today+1}",
    "end": "${today+5}"
  },
  "autonomy": "tiered",
  "context": {
    "notes": "son has sports Wednesday"
  }
}
